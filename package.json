{
  "name": "slack-jira-ticket-bot",
  "version": "1.0.0",
  "description": "Slack bot that lets users connect their Jira account via OAuth and create Jira tickets from natural language.",
  "main": "src/app.js",
  "scripts": {
    "dev": "node src/app.js",
    "start": "node src/app.js",
    "migrate": "npx prisma migrate deploy",
    "migrate:dev": "npx prisma migrate dev",
    "generate": "npx prisma generate",
    "studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@slack/bolt": "^3.19.0",
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "prisma": "^5.14.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
